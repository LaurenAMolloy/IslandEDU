<% layout('/layouts/boilerplate')%>
    <link rel="stylesheet" href="/styles/stars.css">

    <div class="row justify-content-center mb-3">
        <div class="col-6">
            <div id="map" style="width: 400px; height: 300px"></div>
            <div id="carouselExample" class="carousel slide">
                <div class="carousel-inner">
                    <% school.images.forEach((img, i)=> { %>
                        <div class="carousel-item <%= i === 0 ? 'active': ''%>">
                            <img src="<%= img.url %>" class="d-block w-100" alt="">
                        </div>
                        <% }) %>
                </div>
                <% if(school.images.length> 1 ) {%>
                    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample"
                        data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#carouselExample"
                        data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                    <%} %>
            </div>

            <div class="card mb-3 mx-auto">
                <div class="card-body">
                    <h5 class="card-title">
                        <%= school.title %>
                    </h5>
                    <p class="card-text">
                        <%= school.description %>
                    </p>
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">Location:
                        <a href="/schools?location=<%=school.location %>">
                            <%=school.location %>
                        </a>
                    </li>
                    <li class="list-group-item">Price: $<%=school.price %>/year</li>
                    <li class="list-group-item">Submitted By:<%=school.author.username %>
                    </li>
                </ul>
                <% if(currentUser && school.author.equals(currentUser._id)) {%>
                    <div class="card-body d-flex flex-column flex-md-row gap-3">
                        <a class="card-link btn btn-info w-100 w-md-auto" href="/schools/<%=school._id%>/edit">Edit
                            School</a>
                        <form class="w-100 w-md-auto" action="/schools/<%=school._id%>?_method=Delete" method="POST">
                            <button class=" btn btn-danger w-100">Delete</button>
                        </form>
                    </div>
                    <% } %>
                        <a class="btn btn-info w-100 w-md-auto" href="/schools">Back To All Schools</a>
            </div>
        </div>
        <div class="col-6">

            <div id="map" style="width: 100%; height: 300px;"></div>

            <% if(currentUser && school.author.equals(currentUser._id)) {%>
                <h2>Leave a Review</h2>
                <form action="/schools/<%=school._id %>/reviews" method="POST" class="validated-form mb-5" novalidate>
                    <!-- <div class="mb-3">
                        <label class="form-label" for="range">Rating</label>
                        <input class="form-range" type="range" min="1" max="5" id="range" name="review[rating]"
                            required>
                        <div class="invalid-feedback">
                            Please write a review.
                        </div>
                    </div> -->
                    <div class="mb-3">
                        <fieldset class="starability-basic">
                            <legend>First rating:</legend>
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1"
                                checked aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="body">Review</label>
                        <textarea class="form-control" name="review[body]" id="body" cols="30" rows="3"
                            required></textarea>
                        <div class="invalid-feedback">
                            Please write a review.
                        </div>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                    </div>
                    <button class="btn btn-success">Submit</button>
                </form>
                <% } %>
                    <% for(let review of school.reviews) { %>
                        <div class="card mb-3">
                            <div class="card-body">
                                <!-- <h5 class="card-title">
                                    Rating: <%= review.rating %>
                                </h5> -->
                                <h4>Reviewed By: <%= review.author.username %>
                                </h4>
                                <p class="starability-result" data-rating="<%= review.rating %>">
                                    Rated: <%= review.rating %>
                                </p>
                                <p>
                                    Review: <%= review.body %>
                                </p>
                                <% if(currentUser && review.author.equals(currentUser._id)) {%>
                                    <form action="/schools/<%=school._id%>/reviews/<%=review._id%>?_method=DELETE"
                                        method="POST">
                                        <button class="btn btn-sm btn-danger">Delete</button>
                                    </form>
                                    <% } %>
                            </div>
                        </div>
                        <% } %>
        </div>
    </div>
    <script>
        const mapToken = '<%-process.env.MAPBOX_TOKEN%>';
        const school = <%-JSON.stringify(school)%>
    </script>
    <script src="/javascripts/showPageMap.js"></script>