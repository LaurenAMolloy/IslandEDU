<% layout('/layouts/boilerplate') %>

    <div id="cluster-map" style="width: 100%; height: 500px"></div>
    <div class="container py-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="fw-bold">All Schools: <%- location%></h1>
            <a href="/schools/new" class="btn btn-primary">+ Add School</a>
        </div>

        <div class="row g-4">
            <% for(let school of schools) { %>

                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">

                        <!-- Image -->
                        <div class="ratio ratio-4x3">
                            <img src="<%= (school.image && school.image.length) ? school.image[0].url : '/default.jpg' %>"
                                class="card-img-top object-fit-cover" alt="">
                        </div>

                        <!-- Body -->
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-semibold">
                                <%= school.title %>
                            </h5>

                            <p class="card-text text-muted small flex-grow-1">
                                <%= school.description ? school.description.substring(0, 100) : "" %>...
                            </p>

                            <p class="text-muted small mb-3">
                                <span style="color:#212529;">
                                    📍 <%= school.location %>
                                </span>
                            </p>

                            <a href="/schools/<%= school._id %>" class="btn btn-primary mt-auto">
                                View School
                            </a>
                            <%if(location !=="All" ){%>
                                <a href="/schools">All Schools</a>
                                <% } %>
                        </div>

                    </div>
                </div>
                <% } %>
        </div>
    </div>
    <%- "<script>" %>
        const maptilerApiKey = "<%- process.env.MAPTILER_API_KEY %>";
            const schools = {
            type: "FeatureCollection",
            features: <%- JSON.stringify( schools.map(school=> ({
                type: "Feature",
                geometry: school.geometry,
                properties: { popUpMarkup: school?.properties?.popUpMarkup }
                }))
                ) %>
                };
                <%- "</script>" %>

                    <script src="/javascripts/clustermap.js"></script>